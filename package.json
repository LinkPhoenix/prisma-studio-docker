{
  "name": "prisma-studio-docker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "db:pull": "bunx --bun prisma db pull",
    "db:generate": "bunx --bun prisma generate",
    "studio": "bunx --bun prisma studio --browser none",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f prisma-studio"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "prisma": "^7.0.0",
    "typescript": "^5.7.2"
  }
}
