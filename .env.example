# Database — set DATABASE_URL or the variables below (recommended)
# DATABASE_URL=postgresql://user:password@host:5432/mydb?schema=public

DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=mydb
DATABASE_SCHEMA=public

# Port exposed on the host (default: 5555)
STUDIO_PORT=5555

# Re-introspect schema from database on container start (default: false)
PRISMA_DB_PULL_ON_START=false

# Traefik production: see .env.traefik.example (VPS / Portainer)

# --- Setup workflow ---
# Full deployment guide: docs/deployment-overview.md
#
# 1. Copy this file: copy .env.example .env  (Windows) / cp .env.example .env (Linux)
# 2. Edit database variables
# 3. bun install
# 4. bun run db:pull          # introspect database → updates prisma/schema.prisma
# 5. git add prisma/schema.prisma && git commit && git push   # triggers GHCR build
# 6. Local dev:  bun run docker:up
# 7. Prod VPS:   see docs/vps-traefik.md (Traefik) or docs/vps-ssh-tunnel.md (SSH tunnel)
