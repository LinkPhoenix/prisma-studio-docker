# PostgreSQL connection string (required)
# Example: postgresql://user:password@host:5432/database?schema=public
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Port exposed on the host (default: 5555)
STUDIO_PORT=5555

# Re-introspect schema from database on container start (default: false)
# Set to "true" only if the database schema changes frequently
PRISMA_DB_PULL_ON_START=false

# GitHub username for production image (used in docker-compose.prod.yml)
# Example: ghcr.io/linkphoenix/prisma-studio-docker:latest
GITHUB_OWNER=LinkPhoenix

# --- Setup workflow ---
# 1. Copy this file: copy .env.example .env  (Windows) / cp .env.example .env (Linux)
# 2. Edit .env with your DATABASE_URL
# 3. bun install
# 4. bun run db:pull          # introspect database → updates prisma/schema.prisma
# 5. git add prisma/schema.prisma && git commit && git push   # triggers GHCR build
# 6. Local dev:  bun run docker:up
# 7. Hetzner:     docker compose -f docker-compose.prod.yml pull && docker compose -f docker-compose.prod.yml up -d
