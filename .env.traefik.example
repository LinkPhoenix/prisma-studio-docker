# Traefik production — copy to .env on the VPS (never commit .env)
# Usage:
#   cp .env.traefik.example .env
#   nano .env
#   docker compose -f docker-compose.prod.traefik.yml up -d
#
# Guide: docs/vps-traefik.md

# --- Database (required) ---
# Option A — separate variables (recommended):
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_HOST=db.example.com
DATABASE_PORT=5432
DATABASE_NAME=mydb
DATABASE_SCHEMA=public

# Option B — full URL instead (overrides Option A if set):
# DATABASE_URL=postgresql://user:password@db.example.com:5432/mydb?schema=public

PRISMA_DB_PULL_ON_START=false

# --- Traefik router ---
STUDIO_HOST=studio.example.com
TRAEFIK_CERT_RESOLVER=cloudflare
TRAEFIK_NETWORK=traefik

# --- Basic auth (required) ---
# Generate:
#   docker run --rm httpd:2.4-alpine htpasswd -nbB admin 'YOUR_STRONG_PASSWORD'
#
# Paste the full output below (user:hash). Keep double quotes if the hash contains $.
BASIC_AUTH_USERS="admin:$2y$05$REPLACE_WITH_HTPASSWD_OUTPUT"
