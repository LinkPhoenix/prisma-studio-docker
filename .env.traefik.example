# Traefik production — copy to .env on the VPS (never commit .env)
# Usage:
#   cp .env.traefik.example .env
#   nano .env
#   docker compose -f docker-compose.prod.traefik.yml up -d
#
# Guide: docs/vps-traefik.md

# --- Database (required) ---
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_HOST=db.example.com
DATABASE_PORT=5432
DATABASE_NAME=mydb
DATABASE_SCHEMA=public

# Option — full URL instead (overrides variables above if set):
# DATABASE_URL=postgresql://user:password@db.example.com:5432/mydb?schema=public
#
# VPS → remote PostgreSQL: enable TLS/SSL on the server first (NOT covered by this repo).
# Official PostgreSQL guide: https://www.postgresql.org/docs/current/ssl-tcp.html
# Project notes: docs/security.md#database-connection-tls-vps-deployments
# DATABASE_URL=postgresql://user:password@db.example.com:5432/mydb?schema=public&sslmode=require

PRISMA_DB_PULL_ON_START=false

# --- Traefik router ---
STUDIO_HOST=studio.example.com
TRAEFIK_CERT_RESOLVER=cloudflare
TRAEFIK_NETWORK=traefik

# --- Basic auth (required) ---
# On the VPS:
#   sudo apt install apache2-utils
#   htpasswd -nbB admin 'YOUR_STRONG_PASSWORD'
#
# Verify after deploy:
#   docker inspect prisma-studio | grep -i basicauth -A 2
#
# Paste the full output below (user:hash). Keep double quotes if the hash contains $.
BASIC_AUTH_USERS="admin:$2y$05$REPLACE_WITH_HTPASSWD_OUTPUT"
